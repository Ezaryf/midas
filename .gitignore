# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
test-results/

# next.js
/.next/
/.next-dev/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
backend/*.log
backend/logs/

# env files
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# pytest
.pytest_cache/
.pytest-cache-*

# python
**/__pycache__/
*.pyc
*.pyo
.ruff_cache/
backend/venv/
*.egg-info/
dist/
build/
*.egg

# temp
tmp/

# backup files
*.backup

# npm lock (project uses bun)
package-lock.json

# AI tool configs
.agents/
.claude/
.kiro/

# local backups/conflicts
*-Ezaryf.*
